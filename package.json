{
  "name": "mammography-second-opinion",
  "version": "0.1.0",
  "private": true,
  "description": "Clinician-in-the-loop FFDM mammography second-opinion control plane bootstrap.",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "sbom:cyclonedx": "npm sbom --sbom-format cyclonedx --sbom-type application --package-lock-only --omit=dev",
    "sbom:cyclonedx:file": "node scripts/write-cyclonedx-sbom.mjs",
    "start": "node dist/index.js",
    "smoke:health": "node scripts/smoke-health.mjs",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "test:coverage": "node --experimental-test-coverage --import tsx --test tests/**/*.test.ts",
    "validate:public-export": "npm run test && npm run build"
  },
  "keywords": [
    "mammography",
    "ffdm",
    "breast-imaging",
    "second-opinion",
    "clinical-review",
    "typescript",
    "express"
  ],
  "dependencies": {
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "prom-client": "^15.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.1.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
